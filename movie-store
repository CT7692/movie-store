void getData(Movie* ptr)
{
	ifstream mov;
	mov.open("Movies.txt");

	for (int i = 0; i < SIZE; i++)
	{
		mov >> ptr[i].MPAC;
		mov >> ptr[i].year;
		mov >> ptr[i].runTime;
		mov >> ptr[i].checkedIn;
		mov >> ptr[i].checkedOut;
		getline(mov, ptr[i].name);

	}

	sortMovies(ptr);

	mov.close();
}

