void sortMovies(Movie* ptr)
{
	int max;
	

	for (max = SIZE - 1; max > 0; max--)
	{
		for (int i = 0; i < max; i++)
		{
			if (ptr[i].MPAC > ptr[i + 1].MPAC)
			{
				swap(ptr[i], ptr[i + 1]);
			}
		}
	}
}

void swap(int &pa, int &pb)
{
	int swa = pa;
	pa = pb;
	pb = swa;
}

void statistics(Movie* ptr)
{
	const string LINE(60, '*');
	double avg;
	int in, out, tot;
	string newMov, old;

	avg = average(ptr);
	old = oldest(ptr);
	newMov = newest(ptr);
	in = cI(ptr);
	out = cO(ptr);
	tot = total(ptr);

	cout << "There are " << SIZE << " different movies in the store." << endl;
	cout << "The average run time for the " << SIZE <<
		" movies is " << setprecision(1) << fixed << avg << endl;
	cout << "The oldest movie is " << old << endl;
	cout << "The newest movie is " << newMov << endl;
	cout << "There are " << in << " movies checked in." << endl;
	cout << "There are " << out << " movies checked out." << endl;
	cout << "There are " << tot << " copies in this store.\n" << endl;
	cout << LINE << endl;

	menu(ptr);
}

int binarySearch(Movie* ptr, int upc)
{
	int first = 0;
	int last = SIZE - 1;
	int middle;
	int pos = -1;
	bool found = false;
	while (!found && first <= last)
	{
		middle = (first + last) / 2;

		if (ptr[middle].MPAC == upc)
		{
			found = true;
			pos = middle;
		}

		else if (ptr[middle].MPAC > upc)

			last = middle - 1;

		else
			first = middle + 1;
		
	}
	return pos;
}



void rentals(Movie* ptr)
{
	int upc, results;
	char check;
	cout << "Enter movie MPAC: ";
	cin >> upc;

	if (upc == 0)
	{
		menu(ptr);
	}

	results = binarySearch(ptr, upc);

	if (results == -1)
	{
		cout << "That movie is not in the store.\n" << endl;
		

		if (upc == 0)
		{
			menu(ptr);
		}
	}

	else
	{
		cout << "Check in (i) or check out (o)? ";

		cin >> check;
		if (check == 'o')
		{

			if (ptr[results].checkedIn > 0)
			{
				cout << ptr[results].checkedIn - 1 << " copies available and " <<
					ptr[results].checkedOut + 1 << " copies checked out." << endl;

				
			}




			if(ptr[results].checkedIn <= 0)
			{
				cout << "No copies in stock at this time. Try another movie." << endl;
				
				

			}

		}

		if (check == 'i')
		{
			cout << ptr[results].checkedIn + 1 << " copies available and " <<
				ptr[results].checkedOut - 1 << " copies checked out." << endl;
		

			
		}
	}

	
	
}

double average(Movie* ptr)
{
	int total = 0;

	for (int i = 0; i < SIZE; i++)
	{
		total += ptr[i].runTime;
	}
	double average = static_cast<double>(total) / static_cast<double>(SIZE);

	return average;
}

string oldest(Movie* ptr)
{
	int old = ptr[0].year;
	string pos;
	for (int i = 0; i < SIZE; i++)
	{
		if (ptr[i].year < old)
		{
			old = ptr[i].year;
			pos = ptr[i].name;
		}
	}
	return pos;
}

string newest(Movie* ptr)
{
	int newest = 0;
	string pos;
	for (int i = 0; i < SIZE; i++)
	{
		if (newest < ptr[i].year)
		{
			newest = ptr[i].year;
			pos = ptr[i].name;
		}
	}

	return pos;
}

int cI(Movie* ptr)
{
	int in = 0;
	int i = 0;
	for (ptr[i].checkedIn; ptr[i].checkedIn < SIZE; i++)
	{
		in += ptr[i].checkedIn;
	}
	return in;
}

int cO(Movie* ptr)
{
	int out = 0;
	int i = 0;
	for (ptr[i].checkedOut; ptr[i].checkedOut < SIZE; i++)
	{
		out += ptr[i].checkedOut;
	}
	return out;
}

int total(Movie* ptr)
{
	int tot = 0;
	int i = 0;
	for (i; i < SIZE; i++)
	{
		tot += ptr[i].checkedIn;
		tot += ptr[i].checkedOut;
	}
	return tot;
}


